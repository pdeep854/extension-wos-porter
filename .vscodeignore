# VS Code / test scaffolding
.vscode/**
.vscode-test/**

# Sources — the compiled JS in out/ is what ships
src/**
!out/**

# Build-time only (verify-manifests runs at prepublish, not at runtime)
scripts/**

# Node dev tree
node_modules/**
package-lock.json

# Repo hygiene / dev docs (not needed at runtime)
.git/**
.github/**
.gitignore
CODE-OF-CONDUCT.md
CONTRIBUTING.md
SECURITY.md

# Build config
tsconfig.json
**/*.ts
**/*.map

# Packaged output artefacts
*.vsix

# Python build artefacts (never ship compiled bytecode)
**/__pycache__/**
**/*.pyc

# Claude Code plugin packaging (installed via the Claude Code marketplace from
# GitHub, not used by the VS Code extension at runtime)
claude-plugin/**
.claude-plugin/**
